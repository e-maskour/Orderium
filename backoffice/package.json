{
  "name": "orderium-backoffice",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "packageManager": "pnpm@10.5.2",
  "description": "Professional backoffice and management system for Orderium",
  "author": "Orderium Team",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:analyze": "vite build --mode development && tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@orderium/ui": "file:../shared/ui",
    "@tanstack/react-query": "^5.13.4",
    "apexcharts": "^5.3.6",
    "chart.js": "^4.5.1",
    "firebase": "^10.12.0",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.0.0",
    "lucide-react": "^0.294.0",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.7",
    "react": "^18.2.0",
    "react-apexcharts": "^1.9.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "terser": "^5.46.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^5.0.8",
    "vitest": "^2.1.0"
  }
}