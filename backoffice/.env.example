# Orderium Backoffice Environment Variables

# API Configuration
VITE_API_BASE_URL=http://localhost:3000

# CDN Configuration
VITE_S3_BASE_URL=https://your-s3-bucket.s3.amazonaws.com
VITE_CLOUDFLARE_BASE_URL=https://your-cloudflare-domain.com

# Firebase Cloud Messaging Configuration
# SECURITY: Replace with your own Firebase project values — never commit real API keys
# Restrict this key in Google Cloud Console to your production domain only
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
VITE_FIREBASE_VAPID_KEY=your_vapid_key

# Chat AI Agent
VITE_ENABLE_CHAT_AI_AGENT=false
