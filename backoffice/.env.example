# Orderium Backoffice Environment Variables

# API Configuration
VITE_API_BASE_URL=http://localhost:3000

# MinIO Object Storage — public URL accessible by the browser
# Must match the MINIO_PUBLIC_URL set in the API / docker-compose environment.
VITE_MINIO_PUBLIC_URL=http://localhost:9000

# Firebase Cloud Messaging Configuration
# SECURITY: Replace with your own Firebase project values — never commit real API keys
# Restrict this key in Google Cloud Console to your production domain only
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
VITE_FIREBASE_VAPID_KEY=your_vapid_key

# Chat AI Agent
VITE_ENABLE_CHAT_AI_AGENT=false
