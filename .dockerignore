# Root-level .dockerignore
# Prevents copying unnecessary files when building from root context

# node_modules everywhere
node_modules
**/node_modules

# Build outputs
dist
**/dist
build
**/build
.next
**/.next

# Env files (passed as build-args or mounted at runtime)
.env
.env.local
.env.*.local

# VCS
.git
.gitignore
**/.gitignore

# Editor / OS
.vscode
.idea
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
*.log

# Docs & tests (not needed in image)
*.md
!README.md
coverage
**/coverage
playwright/
QA Tests/
docs/

# Docker files (no need to copy these into the image)
docker-compose*.yml
**/Dockerfile
**/.dockerignore

