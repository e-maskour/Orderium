# Resilient pnpm fetching for high-latency connections (VPS far from npm CDN)
# These settings dramatically reduce tarball timeout failures on slow links.
network-timeout=120000
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-retries=5

# Allow only explicitly listed packages to run post-install build scripts.
# This is enforced via the "pnpm.onlyBuiltDependencies" key in package.json.
# The setting below makes pnpm skip the interactive approve-builds prompt
# in CI / Docker environments where stdin is not a TTY.
ignore-scripts=false
